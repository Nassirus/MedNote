rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── schedule_items ────────────────────────────────────────────────
    // Patient reads/writes own items only.
    // Doctor writes to patient's items via doctor_appointments
    // (direct doctor→patient item creation happens in DoctorCalendar, verified by patient_uid match)
    match /schedule_items/{itemId} {
      allow read, update, delete: if request.auth != null &&
        resource.data.user_id == request.auth.uid;

      // Create: own items OR authenticated user (doctors creating for patients)
      allow create: if request.auth != null && (
        request.resource.data.user_id == request.auth.uid ||
        request.resource.data.added_by == 'doctor'
      );
    }

    // ── profiles ──────────────────────────────────────────────────────
    // Own profile: full access
    // Any authenticated user: read-only (for doctor to look up patient by UID)
    match /profiles/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ── doctor_patients ───────────────────────────────────────────────
    // Doctor manages their own patient links
    match /doctor_patients/{docId} {
      allow read, create: if request.auth != null && (
        resource == null ||
        resource.data.doctor_uid == request.auth.uid
      );
      allow update, delete: if request.auth != null &&
        resource.data.doctor_uid == request.auth.uid;
    }

    // ── doctor_appointments ───────────────────────────────────────────
    // Doctor manages their own appointments
    match /doctor_appointments/{docId} {
      allow read, create: if request.auth != null && (
        resource == null ||
        resource.data.doctor_uid == request.auth.uid
      );
      allow update, delete: if request.auth != null &&
        resource.data.doctor_uid == request.auth.uid;
    }

    // ── prescription_requests ─────────────────────────────────────────
    // Doctor creates, patient accepts/rejects
    match /prescription_requests/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.patient_uid == request.auth.uid ||
        resource.data.doctor_uid  == request.auth.uid
      );
      allow update, delete: if request.auth != null &&
        resource.data.patient_uid == request.auth.uid;
    }

    // ── notes ─────────────────────────────────────────────────────────
    // Own notes only. Using request.resource on create (resource is null for new docs)
    match /notes/{docId} {
      allow read, update, delete: if request.auth != null &&
        resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.user_id == request.auth.uid;
    }

    // ── streaks ───────────────────────────────────────────────────────
    match /streaks/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
