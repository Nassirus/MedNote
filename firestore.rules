rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── schedule_items ────────────────────────────────────────────────
    // Пациент читает/пишет свои события
    // Врач пишет в события пациента (если есть связь doctor_patients)
    match /schedule_items/{itemId} {
      allow read: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        exists(/databases/$(database)/documents/doctor_patients/$(
          request.auth.uid + '_' + resource.data.user_id
        ))
      );
      allow create: if request.auth != null && (
        request.resource.data.user_id == request.auth.uid ||
        exists(/databases/$(database)/documents/doctor_patients/$(
          request.auth.uid + '_' + request.resource.data.user_id
        ))
      );
      allow update, delete: if request.auth != null &&
        resource.data.user_id == request.auth.uid;
    }

    // ── profiles ──────────────────────────────────────────────────────
    // Каждый читает/пишет только свой профиль
    // Врач может читать профиль пациента (для поиска по email)
    match /profiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null;
    }

    // ── doctor_patients ───────────────────────────────────────────────
    // Врач создаёт и читает свои записи
    // ID документа произвольный (addDoc), фильтр по doctor_uid
    match /doctor_patients/{docId} {
      allow read, create, delete: if request.auth != null && (
        resource == null ||
        resource.data.doctor_uid == request.auth.uid
      );
      allow update: if request.auth != null &&
        resource.data.doctor_uid == request.auth.uid;
    }

    // ── doctor_appointments ───────────────────────────────────────────
    // Врач полностью управляет своими приёмами
    match /doctor_appointments/{docId} {
      allow read, create, update, delete: if request.auth != null && (
        resource == null ||
        resource.data.doctor_uid == request.auth.uid
      );
    }

    // ── notes ─────────────────────────────────────────────────────────
    match /notes/{docId} {
      allow read, write: if request.auth != null &&
        resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null &&
        request.resource.data.user_id == request.auth.uid;
    }

    // ── streaks / profiles sub-collections ───────────────────────────
    match /streaks/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
